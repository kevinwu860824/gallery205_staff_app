# Supabase (anon key 設計上是公開的，不需要保密)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Gemini API Key（用於 smart_scanner_screen 收據掃描功能）
# 到 Google Cloud Console → APIs & Services → Credentials 建立
GEMINI_API_KEY=your-gemini-api-key

# Sentry 錯誤追蹤
# 透過 flutter build --dart-define=SENTRY_DSN=https://... 注入
# 不放在 .env，改用 CI/CD 環境變數或 build script 傳入
